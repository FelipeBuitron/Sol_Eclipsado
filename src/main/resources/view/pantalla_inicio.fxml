<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="15" style="-fx-background-color: #000000;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/24.0.1" fx:controller="main.java.controller.PantallaInicioController">

    <Label text="SOL ECLIPSADO" textFill="#fff3f3">
      <font>
         <Font name="Quick Town" size="43.0" />
      </font></Label>

    <Label text="Ingrese la palabra secreta" textFill="#a4a1a1">
      <font>
         <Font name="Rockwell Condensed" size="20.0" />
      </font></Label>

    <TextField fx:id="campoPalabra" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="25.0" minWidth="300.0" prefHeight="43.0" prefWidth="300.0" />

    <Button fx:id="botonJugar" onAction="#jugar" text="Jugar">
      <font>
         <Font name="Rockwell Condensed" size="16.0" />
      </font></Button>

</VBox>
