<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="15" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.controller.PantallaInstruccionesController">

    <Label text="SOL ECLIPSADO" textFill="#fff3f3">
        <font>
            <Font name="Quick Town" size="43.0" />
        </font></Label>

    <Label text="INSTRUCCIONES: " textFill="#a4a1a1" wrapText="true">
        <font>
            <Font name="Rockwell Condensed" size="20.0" />
        </font></Label>
   <Label text="1. Ingrese la palabra secreta que el jugador debe adivinar. " textFill="WHITE">
      <font>
         <Font name="Rockwell Condensed" size="18.0" />
      </font>
   </Label>
   <Label text="2. Dar click en Jugar. " textFill="WHITE">
      <font>
         <Font name="Rockwell Condensed" size="18.0" />
      </font>
   </Label>
   <Label text="3. Inicia el juego y adivina letra por letra la palabra secreta. Si hay letras repetidas, debaras adivinar cada una." textAlignment="CENTER" textFill="#f8f5f5" wrapText="true">
      <font>
         <Font name="Rockwell Condensed" size="18.0" />
      </font>
   </Label>
   <Label text="4. Tienes hasta 5 oportunidades de comter errores." textFill="WHITE">
      <font>
         <Font name="Rockwell Condensed" size="18.0" />
      </font>
   </Label>
   <Label text="5. Con el botón de &quot;Ayuda&quot; puedes descubrir la siguiente letra de la palabra (solo tienes 3 oportunidades de ayuda)" textAlignment="CENTER" textFill="WHITE" wrapText="true">
      <font>
         <Font name="Rockwell Condensed" size="18.0" />
      </font>
   </Label>

    <Button fx:id="botonContinuar" onAction="#Continuar" text="Continuar">
        <font>
            <Font name="Rockwell Condensed" size="16.0" />
        </font></Button>

</VBox>
